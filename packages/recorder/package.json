{
  "name": "@clarionhq/recorder",
  "version": "0.0.1",
  "description": "Clarion recorder — PCM capture to m4a for React Native (offline-first)",
  "main": "lib/index.js",
  "types": "lib/index.d.ts",
  "react-native": "src/index.ts",
  "source": "src/index.ts",
  "files": [
    "lib",
    "src",
    "android/src",
    "android/build.gradle",
    "android/gradle.properties",
    "android/AndroidManifest.xml",
    "ios",
    "nitrogen",
    "nitro.json",
    "clarionhq-recorder.podspec",
    "README.md",
    "LICENSE",
    "!**/__tests__",
    "!**/__fixtures__",
    "!**/.*"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "nitro:codegen": "nitrogen",
    "clean": "rm -rf lib nitrogen"
  },
  "keywords": [
    "react-native",
    "audio",
    "recorder",
    "pcm",
    "m4a",
    "aac",
    "audiorecord",
    "avaudioengine",
    "nitro-modules",
    "turbomodule",
    "fabric",
    "new-architecture"
  ],
  "dependencies": {
    "@clarionhq/core": "workspace:*"
  },
  "peerDependencies": {
    "react": ">=18.3.1",
    "react-native": ">=0.77.0",
    "react-native-nitro-modules": ">=0.35.0"
  },
  "devDependencies": {
    "nitrogen": "^0.35.6",
    "react": "18.3.1",
    "react-native": "0.77.3",
    "react-native-nitro-modules": "^0.35.6"
  },
  "license": "MIT",
  "publishConfig": { "access": "public" },
  "repository": { "type": "git", "url": "https://github.com/Th4nderG0d/clarion", "directory": "packages/recorder" }
}
