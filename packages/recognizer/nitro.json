{
  "$schema": "https://nitro.margelo.com/nitro.schema.json",
  "cxxNamespace": ["clarion", "recognizer"],
  "ios": {
    "iosModuleName": "ClarionRecognizer"
  },
  "android": {
    "androidNamespace": ["clarion", "recognizer"],
    "androidCxxLibName": "ClarionRecognizer"
  },
  "autolinking": {
    "ClarionRecognizer": {
      "ios": {
        "language": "swift",
        "implementationClassName": "HybridClarionRecognizer"
      },
      "android": {
        "language": "kotlin",
        "implementationClassName": "HybridClarionRecognizer"
      }
    }
  },
  "ignorePaths": ["node_modules", "lib"]
}
