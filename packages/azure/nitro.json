{
  "$schema": "https://nitro.margelo.com/nitro.schema.json",
  "cxxNamespace": ["clarion", "azure"],
  "ios": {
    "iosModuleName": "ClarionAzure"
  },
  "android": {
    "androidNamespace": ["clarion", "azure"],
    "androidCxxLibName": "ClarionAzure"
  },
  "autolinking": {
    "ClarionAzure": {
      "ios": {
        "language": "swift",
        "implementationClassName": "HybridClarionAzure"
      },
      "android": {
        "language": "kotlin",
        "implementationClassName": "HybridClarionAzure"
      }
    }
  },
  "ignorePaths": ["node_modules", "lib"]
}
