{
  "$schema": "https://nitro.margelo.com/nitro.schema.json",
  "cxxNamespace": ["clarion", "audio_tap"],
  "ios": {
    "iosModuleName": "ClarionAudioTap"
  },
  "android": {
    "androidNamespace": ["clarion", "audio_tap"],
    "androidCxxLibName": "ClarionAudioTap"
  },
  "autolinking": {
    "ClarionAudioTap": {
      "ios": {
        "language": "swift",
        "implementationClassName": "HybridClarionAudioTap"
      },
      "android": {
        "language": "kotlin",
        "implementationClassName": "HybridClarionAudioTap"
      }
    }
  },
  "ignorePaths": ["node_modules", "lib"]
}
